# Application Settings
APP_NAME="Personal Finance Intelligence"
APP_VERSION="2.0.0"
APP_ENV="development"
DEBUG=False

# Database
DATABASE_URL=sqlite+aiosqlite:///./statements.db
# DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/database_name

# File Upload
UPLOAD_DIR=./static/uploads
MAX_FILE_SIZE_MB=10

# Server
HOST=0.0.0.0
PORT=8000

# Authentication & Security
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
SESSION_SECRET_KEY=replace-with-openssl-rand-hex-32
SESSION_TIMEOUT_MINUTES=30

# Claude AI (Anthropic) - Required for Vision parsing and AI insights
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Extraction model: claude-haiku-4-5 (cheap, default) | claude-sonnet-4-5 (most accurate)
EXTRACTION_MODEL=claude-haiku-4-5

# Max output tokens for the extraction response.
# 16000 handles statements with 40+ transactions per page.
EXTRACTION_MAX_TOKENS=16000

# Defaults
DEFAULT_CURRENCY=BDT
IMAGE_DPI=200

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

FACEBOOK_APP_ID=<from Facebook Developer portal>
FACEBOOK_APP_SECRET=<from Facebook Developer portal>
FACEBOOK_REDIRECT_URI=https://kipta.app/api/auth/facebook/callback  # production only

# Registration
# Set to false to disable public sign-up (useful for invite-only or single-user deployments)
ALLOW_SIGNUP=true

# SMTP Email (optional — required for password reset emails)
# When not configured, the "Forgot password?" link is automatically hidden.
# Example providers:
#   Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use an App Password)
#   SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USERNAME=apikey
#   Mailgun:  SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@personalfinance.app
SMTP_FROM_NAME="Personal Finance Intelligence"

# Frontend URL for links in email
FRONTEND_URL=http://localhost:8000
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

ENCRYPTION_KEY=
HASH_SALT=