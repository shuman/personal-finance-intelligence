# Application Settings
APP_NAME="Personal Finance Intelligence"
APP_VERSION="2.0.0"
DEBUG=False
# Keep HTTPS_ONLY=False on Railway — TLS is terminated at Railway's proxy edge,
# not inside the container. Setting True breaks the internal HTTP healthcheck.
HTTPS_ONLY=False

# Database (PostgreSQL for Railway / SQLite for local dev)
# Railway will inject DATABASE_URL automatically — pointing to a Postgres instance.
# For local dev, use SQLite:
DATABASE_URL=sqlite+aiosqlite:///./statements.db
# For local dev with Postgres:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finance_db

# File Upload
UPLOAD_DIR=./static/uploads
MAX_FILE_SIZE_MB=10

# Server (Railway injects PORT automatically)
HOST=0.0.0.0
PORT=8000

# Authentication (CHANGE THIS IN PRODUCTION)
SECRET_KEY=super_secret_jwt_key_please_change_in_production_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# Google OAuth (optional — enables "Sign in with Google")
# Obtain credentials from: https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URIs to: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Claude AI (Anthropic) — Required for Vision parsing and AI insights
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Extraction model: claude-haiku-4-5 (cheap, default) | claude-sonnet-4-5 (most accurate)
EXTRACTION_MODEL=claude-haiku-4-5

# Max output tokens for the extraction response.
EXTRACTION_MAX_TOKENS=16000

# Defaults
DEFAULT_CURRENCY=BDT
